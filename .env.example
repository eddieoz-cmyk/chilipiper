# Chili Piper export folder (meetings.csv, concierge.csv, chilirules.json, users-export-*.csv)
CHILIPIPER_DATA_DIR=../chilipiper
CHILIPIPER_YEAR=2026

# Routing: use local export, live API, CSV, or Google Sheet
ROUTING_SOURCE=chilipiper-file
# ROUTING_SOURCE=api
ROUTING_API_URL=https://fire.chilipiper.com/api/fire-edge/v1/org/rule/list?page=0&pageSize=200
ROUTING_API_TOKEN=your_api_key_here

# Optional: keep offline POD mapping from CSV while rules come from the API
# ROUTING_OFFLINE_CSV=data/routing-offline-distribution.csv

# Meetings: load from Chili Piper exports (default when CHILIPIPER_DATA_DIR exists)
MEETINGS_SOURCE=chilipiper

# Or Google Sheet (concierge + BDR handoff tabs)
# MEETINGS_SOURCE=sheets
# Share the sheet: anyone with the link can view (required for CSV export)
MEETINGS_SOURCE=sheets
MEETINGS_SPREADSHEET_ID=your_spreadsheet_id_here
MEETINGS_CONCIERGE_GID=0
MEETINGS_HANDOFF_GID=your_handoff_tab_gid

# Or load from CSV files (default uses sample data until sheet is configured)
# MEETINGS_SOURCE=csv
# MEETINGS_CONCIERGE_CSV=data/meetings-concierge-sample.csv
# MEETINGS_HANDOFF_CSV=data/meetings-handoff-sample.csv

# Optional: if column headers differ, comma-separated aliases per field
# MEETINGS_COL_STATUS=Meeting Status,Status
# MEETINGS_COL_BOOKED_LIVE=Booked Live,Live Booking
# MEETINGS_COL_HAPPENED=Meeting Held,Attended
# MEETINGS_COL_HANDOFF=Handoff to AE,BDR Handoff
